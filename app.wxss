page {
  min-height: 100%;
  background: #f3faf8;
  color: #143b35;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.page {
  min-height: 100vh;
  padding: 58rpx 38rpx 72rpx;
  box-sizing: border-box;
}

.brand-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 54rpx;
  color: #007968;
  font-size: 26rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  color: #007968;
  font-size: 24rpx;
  font-weight: 900;
}

.brand-bell {
  margin-left: auto;
  color: #007968;
  font-size: 26rpx;
}

.section {
  margin-top: 44rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  color: #173d36;
  font-size: 32rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.section-more {
  color: #6c817c;
  font-size: 24rpx;
  font-weight: 700;
}

.card {
  border-radius: 32rpx;
  background: #ffffff;
  border: 2rpx solid rgba(215, 232, 226, 0.72);
  box-shadow: 0 18rpx 44rpx rgba(11, 78, 67, 0.08);
  box-sizing: border-box;
}

.card + .card {
  margin-top: 28rpx;
}

.card-pad {
  padding: 30rpx;
}

.muted {
  color: #6c817c;
}

.tiny {
  color: #6c817c;
  font-size: 22rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #e7faf5;
  color: #007968;
  font-size: 21rpx;
  line-height: 1;
  font-weight: 700;
}

.tag.peach {
  background: #fff0e6;
  color: #b86532;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  border-radius: 999rpx;
  background: #007968;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 28rpx rgba(0, 121, 104, 0.22);
}

.secondary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 70rpx;
  border-radius: 999rpx;
  background: #e7faf5;
  color: #007968;
  font-size: 26rpx;
  font-weight: 800;
}

.item-title {
  color: #173d36;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
}

.item-desc {
  margin-top: 10rpx;
  color: #5f746f;
  font-size: 24rpx;
  line-height: 1.58;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 14rpx;
  color: #5f746f;
  font-size: 22rpx;
}

.empty-state {
  margin-top: 40rpx;
  text-align: center;
}
