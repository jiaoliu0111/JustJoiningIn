page {
  min-height: 100%;
  background: #fff3d8;
  color: #2e251f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 56rpx;
  box-sizing: border-box;
}

.section {
  margin-top: 30rpx;
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.section-more {
  color: #9b8f78;
  font-size: 24rpx;
  font-weight: 500;
}

.card {
  border-radius: 24rpx;
  background: #fffdf7;
  box-shadow: 0 12rpx 30rpx rgba(46, 37, 31, 0.07);
  box-sizing: border-box;
}

.card + .card {
  margin-top: 18rpx;
}

.card-pad {
  padding: 24rpx;
}

.muted {
  color: #8d826e;
}

.tiny {
  color: #9b8f78;
  font-size: 22rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #fff1df;
  color: #b95d20;
  font-size: 22rpx;
  line-height: 1;
}

.tag.green {
  background: #e8f4df;
  color: #4f8548;
}

.tag.blue {
  background: #fff7dc;
  color: #8d6c22;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 92rpx;
  border-radius: 999rpx;
  background: #ff8a3d;
  color: #fffdf7;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 14rpx 28rpx rgba(255, 138, 61, 0.24);
}

.secondary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  border-radius: 999rpx;
  background: #fffdf7;
  color: #2e251f;
  border: 2rpx solid #eaddc7;
  font-size: 28rpx;
  font-weight: 700;
}

.danger-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  border-radius: 16rpx;
  background: #fff0e7;
  color: #c95625;
  font-size: 28rpx;
  font-weight: 700;
}

.item-title {
  color: #2e251f;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.35;
}

.item-desc {
  margin-top: 10rpx;
  color: #766c5b;
  font-size: 25rpx;
  line-height: 1.55;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 12rpx;
  color: #8d826e;
  font-size: 23rpx;
}

.two-col {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}
