<view class="page home-page">
  <view class="hero">
    <view class="hero-top">
      <view class="hero-date">
        <text class="hero-city">上海 · 附近小热闹</text>
      </view>
      <view class="hero-distance">
        <text class="hero-time">{{currentTime}}</text>
        <text class="hero-day">{{currentDate}} {{currentWeekday}}</text>
        <text class="hero-range">附近 3km</text>
      </view>
    </view>
    <view class="hero-title">附近刚好有点小热闹</view>
    <view class="hero-subtitle">免费、近、马上能去。不用约人，也不用报名，路过看看就行。</view>
    <view class="search-pill">附近有什么免费小热闹？</view>
    <view class="tag-row">
      <text class="tag">免费优先</text>
      <text class="tag green">步行可达</text>
      <text class="tag blue">不用社交硬聊</text>
    </view>
  </view>

  <view class="soft-reminder card card-pad">
    <view>
      <view class="item-title">街角免费咖啡正在试饮</view>
      <view class="item-desc">步行 6 分钟，现在开始，不用报名，拿一杯就走。</view>
    </view>
    <view class="reminder-dot"></view>
  </view>

  <view class="primary-btn instant-btn" bindtap="goReason">给我一个出门理由</view>

  <view class="section">
    <view class="section-title">
      <text>附近地图气泡</text>
      <text class="section-more" bindtap="goBustle">全部</text>
    </view>
    <view class="map-card card">
      <view class="map-river"></view>
      <view class="map-road road-a"></view>
      <view class="map-road road-b"></view>
      <block wx:for="{{moments}}" wx:key="id">
        <view class="map-pin pin-{{index}} {{item.color}}" data-type="moment" data-id="{{item.id}}" bindtap="openDetail">
          <view class="pin-core"></view>
          <text>{{item.bubble}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="section">
    <view class="section-title">
      <text>现在能去的小热闹</text>
      <text class="section-more" bindtap="goBustle">更多</text>
    </view>
    <block wx:for="{{featuredMoments}}" wx:key="id">
      <view class="card card-pad list-item" data-type="moment" data-id="{{item.id}}" bindtap="openDetail">
        <view>
          <view class="item-title">{{item.title}}</view>
          <view class="item-desc">步行 {{item.walkMinutes}} 分钟 · {{item.timeLabel}} · {{item.lowPressureNote}}</view>
          <view class="tag-row">
            <text class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
          </view>
        </view>
        <view class="join-chip">{{item.walkMinutes}}′</view>
      </view>
    </block>
  </view>

  <view class="section">
    <view class="section-title">
      <text>出门理由</text>
      <text class="section-more" bindtap="goReason">换一个</text>
    </view>
    <block wx:for="{{reasons}}" wx:key="id">
      <view class="card card-pad" data-type="reason" data-id="{{item.id}}" bindtap="openDetail">
        <view class="tiny">低压力理由</view>
        <view class="item-title">{{item.title}}</view>
        <view class="item-desc">{{item.subtitle}}</view>
      </view>
    </block>
  </view>

  <view class="section">
    <view class="section-title">
      <text>现成放空路线</text>
    </view>
    <view class="two-col">
      <block wx:for="{{routes}}" wx:key="id">
        <view class="route-card card card-pad" data-type="route" data-id="{{item.id}}" bindtap="openDetail">
          <view class="route-time">{{item.duration}}</view>
          <view class="item-title">{{item.title}}</view>
          <view class="item-desc">{{item.difficulty}} · {{item.distance}}km</view>
        </view>
      </block>
    </view>
  </view>

  <view class="section checklist card card-pad">
    <view class="section-title">
      <text>出门只要三件事</text>
    </view>
    <view class="check-item" wx:for="{{checklist}}" wx:key="*this">
      <text class="check-dot"></text>
      <text>{{item}}</text>
    </view>
  </view>
</view>
