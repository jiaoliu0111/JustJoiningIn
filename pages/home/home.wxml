<view class="page home-page">
  <view class="top-nav">
    <view class="city-selector" bindtap="switchCity">
      <text class="city-dot">⌖</text>
      <text>{{cityName}}</text>
      <text class="city-arrow">⌄</text>
    </view>
    <view class="search-box">
      <text class="search-icon">⌕</text>
      <input
        value="{{searchKeyword}}"
        placeholder="搜索地点、关键词、活动"
        confirm-type="search"
        bindinput="updateSearch"
        bindconfirm="goSearch"
      />
    </view>
    <view class="message-btn" bindtap="openMessages">⌂</view>
  </view>

  <swiper class="hero-swiper" indicator-dots autoplay circular interval="3600">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <view class="banner-card" bindtap="goBustle">
        <image class="banner-image" src="{{item.image}}" mode="aspectFill" />
        <view class="banner-shade"></view>
        <view class="banner-copy">
          <view class="banner-badge">{{item.badge}}</view>
          <view class="banner-title">{{item.title}}</view>
          <view class="banner-subtitle">{{item.subtitle}}</view>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <scroll-view class="quick-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="quick-entry-row">
      <view
        class="quick-entry"
        wx:for="{{quickEntries}}"
        wx:key="id"
        data-filter="{{item.filterId}}"
        bindtap="goQuickEntry"
      >
        <view class="quick-icon">
          <image wx:if="{{item.imageIcon}}" class="quick-icon-image" src="{{item.imageIcon}}" mode="aspectFit" />
          <text wx:else>{{item.icon}}</text>
        </view>
        <view class="quick-label">{{item.label}}</view>
      </view>
    </view>
  </scroll-view>

  <view class="portal-section">
    <view class="section-head">
      <view class="section-title">附近好去处</view>
      <view class="more-link" bindtap="goBustle">查看更多</view>
    </view>
    <view class="nearby-list">
      <view
        class="nearby-card"
        wx:for="{{nearbyMoments}}"
        wx:key="id"
        data-type="moment"
        data-id="{{item.id}}"
        bindtap="openDetail"
      >
        <image class="nearby-thumb" src="{{item.image}}" mode="aspectFill" />
        <view class="nearby-main">
          <view class="place-title">{{item.title}}</view>
          <view class="place-meta">{{item.place}} · {{item.distanceLabel}}</view>
          <view class="tag-row compact-tags">
            <text class="tag" wx:for="{{item.previewTags}}" wx:key="*this">{{item}}</text>
          </view>
          <view class="place-desc">{{item.description}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="portal-section">
    <view class="section-head">
      <view class="section-title">本周人气逛点</view>
      <view class="more-link" bindtap="goBustle">查看更多</view>
    </view>
    <scroll-view class="popular-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="popular-row">
        <view
          class="popular-card"
          wx:for="{{popularMoments}}"
          wx:key="id"
          data-type="moment"
          data-id="{{item.id}}"
          bindtap="openDetail"
        >
          <image class="popular-image" src="{{item.image}}" mode="aspectFill" />
          <view class="popular-title">{{item.title}}</view>
          <view class="popular-meta">评分 {{item.rating}} · {{item.checkins}} 人打卡</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="portal-section">
    <view class="section-head">
      <view class="section-title">懒人游玩方案</view>
      <view class="more-link" bindtap="goRecommend">查看更多</view>
    </view>
    <view class="route-list">
      <view
        class="route-card"
        wx:for="{{routePlans}}"
        wx:key="id"
        data-type="route"
        data-id="{{item.id}}"
        bindtap="openDetail"
      >
        <view class="route-top">
          <view class="route-title">{{item.title}}</view>
          <view class="route-time">{{item.duration}}</view>
        </view>
        <view class="route-stops">{{item.stopText}}</view>
        <view class="route-bottom">
          <text>{{item.peopleLabel}}</text>
          <text>{{item.difficulty}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="card card-pad empty-state" wx:if="{{errorText}}">
    <view class="item-title">今天的推荐暂时没加载出来</view>
    <view class="item-desc">{{errorText}}</view>
  </view>
</view>
