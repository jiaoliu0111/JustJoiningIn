.home-page {
  padding-bottom: 140rpx;
}

.clock-card {
  width: 100%;
  min-height: 220rpx;
  margin: 42rpx auto 0;
  padding: 30rpx 34rpx 34rpx;
  border-radius: 34rpx;
  background: #8fe5d0;
  color: #007968;
  text-align: center;
  box-shadow: 0 18rpx 40rpx rgba(0, 121, 104, 0.14);
  box-sizing: border-box;
}

.clock-top {
  display: flex;
  justify-content: center;
  gap: 28rpx;
  color: #097d70;
  font-size: 22rpx;
  font-weight: 800;
}

.clock-time {
  margin-top: 16rpx;
  color: #007968;
  font-size: 92rpx;
  line-height: 1;
  font-weight: 900;
  letter-spacing: 0;
}

.clock-caption {
  margin-top: 18rpx;
  color: rgba(0, 121, 104, 0.72);
  font-size: 22rpx;
  text-align: center;
}

.daily-card {
  margin-top: 54rpx;
  text-align: center;
}

.daily-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 34rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #e7faf5;
  color: #007968;
  font-size: 18rpx;
  font-weight: 800;
}

.daily-title {
  max-width: 280rpx;
  margin-top: 22rpx;
  margin-left: auto;
  margin-right: auto;
  color: #173d36;
  font-size: 38rpx;
  line-height: 1.25;
  font-weight: 900;
}

.daily-desc {
  max-width: 430rpx;
  margin: 22rpx auto 0;
  color: #526a65;
  font-size: 23rpx;
  line-height: 1.62;
}

.daily-action {
  width: 226rpx;
  min-height: 64rpx;
  margin: 26rpx auto 0;
  font-size: 23rpx;
}

.daily-image {
  display: block;
  width: 278rpx;
  height: 214rpx;
  margin: 28rpx auto 0;
  border-radius: 30rpx;
  background: #f7eee4;
}

.hot-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 258rpx;
  margin-top: 58rpx;
  margin-bottom: 58rpx;
  padding: 44rpx 32rpx;
  border-radius: 34rpx;
  background: #8fe5d0;
  color: #007968;
  box-shadow: 0 18rpx 40rpx rgba(0, 121, 104, 0.14);
  box-sizing: border-box;
}

.hot-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #007968;
  box-shadow: 0 10rpx 22rpx rgba(0, 121, 104, 0.12);
}

.hot-icon-core {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  border: 5rpx solid #007968;
  box-sizing: border-box;
}

.hot-icon-core::after {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 8rpx;
  width: 9rpx;
  height: 9rpx;
  border-radius: 50%;
  background: #007968;
}

.hot-icon-core::before {
  content: "";
  position: absolute;
  right: -12rpx;
  bottom: -13rpx;
  width: 18rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #007968;
  transform: rotate(-45deg);
}

.hot-title {
  margin-top: 28rpx;
  font-size: 34rpx;
  font-weight: 900;
}

.hot-desc {
  margin-top: 10rpx;
  color: rgba(0, 121, 104, 0.72);
  font-size: 22rpx;
}

.hot-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  margin-top: 22rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 121, 104, 0.28);
  font-size: 24rpx;
}

.home-copy {
  color: #38554f;
  font-size: 25rpx;
  line-height: 1.72;
}

.habit-list {
  margin-top: 26rpx;
}

.habit-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 14rpx;
  color: #38554f;
  font-size: 24rpx;
}

.habit-check {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #ffd2ad;
  color: #b86532;
  font-size: 22rpx;
  font-weight: 900;
}

.landscape-image {
  display: block;
  width: 100%;
  height: 170rpx;
  margin-top: 42rpx;
  border-radius: 28rpx;
  background: #d9f4ed;
}
