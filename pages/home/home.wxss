.home-page {
  padding-bottom: 140rpx;
}

.top-nav {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 82rpx;
}

.city-selector,
.message-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 62rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #173d36;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 24rpx rgba(18, 74, 64, 0.08);
}

.city-selector {
  gap: 6rpx;
  padding: 0 18rpx;
  white-space: nowrap;
}

.city-dot,
.city-arrow {
  color: #007968;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
  min-height: 62rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(18, 74, 64, 0.08);
  box-sizing: border-box;
}

.search-icon {
  margin-right: 10rpx;
  color: #007968;
  font-size: 28rpx;
  font-weight: 900;
}

.search-box input {
  flex: 1;
  min-width: 0;
  color: #173d36;
  font-size: 24rpx;
}

.message-btn {
  width: 62rpx;
  color: #007968;
}

.hero-swiper {
  height: 310rpx;
  margin-top: 26rpx;
  border-radius: 28rpx;
  overflow: hidden;
}

.banner-card {
  position: relative;
  height: 100%;
  overflow: hidden;
  border-radius: 28rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-shade {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(23, 61, 54, 0.08), rgba(23, 61, 54, 0.74));
}

.banner-copy {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 30rpx;
  color: #ffffff;
}

.banner-badge {
  display: inline-flex;
  min-height: 34rpx;
  padding: 0 16rpx;
  align-items: center;
  border-radius: 999rpx;
  background: #8fe5d0;
  color: #173d36;
  font-size: 20rpx;
  font-weight: 900;
}

.banner-title {
  margin-top: 14rpx;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.2;
}

.banner-subtitle {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 24rpx;
}

.quick-scroll {
  margin-top: 28rpx;
  white-space: nowrap;
}

.quick-entry-row {
  display: flex;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

.quick-entry {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 116rpx;
}

.quick-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 86rpx;
  height: 86rpx;
  border-radius: 28rpx;
  background: #ffffff;
  color: #007968;
  font-size: 34rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 28rpx rgba(18, 74, 64, 0.08);
}

.quick-icon-image {
  width: 58rpx;
  height: 58rpx;
}

.quick-label {
  margin-top: 12rpx;
  color: #173d36;
  font-size: 22rpx;
  font-weight: 800;
}

.portal-section {
  margin-top: 42rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 18rpx;
}

.section-title {
  color: #173d36;
  font-size: 34rpx;
  font-weight: 900;
}

.more-link {
  color: #007968;
  font-size: 23rpx;
  font-weight: 900;
  white-space: nowrap;
}

.nearby-list,
.route-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.nearby-card {
  display: flex;
  gap: 18rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(18, 74, 64, 0.08);
}

.nearby-thumb {
  width: 170rpx;
  height: 170rpx;
  border-radius: 14rpx;
  background: #d9f4ed;
}

.nearby-main {
  flex: 1;
  min-width: 0;
}

.place-title,
.popular-title,
.route-title {
  color: #173d36;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.35;
}

.place-meta,
.popular-meta,
.route-stops {
  margin-top: 8rpx;
  color: #607872;
  font-size: 22rpx;
  line-height: 1.42;
}

.compact-tags {
  margin-top: 12rpx;
}

.place-desc {
  margin-top: 12rpx;
  color: #48645d;
  font-size: 22rpx;
  line-height: 1.5;
}

.popular-scroll {
  white-space: nowrap;
}

.popular-row {
  display: flex;
  gap: 18rpx;
  padding-bottom: 4rpx;
}

.popular-card {
  flex: 0 0 auto;
  width: 300rpx;
  padding: 14rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(18, 74, 64, 0.08);
  box-sizing: border-box;
}

.popular-image {
  width: 100%;
  height: 170rpx;
  border-radius: 14rpx;
  background: #d9f4ed;
}

.popular-title {
  margin-top: 14rpx;
  font-size: 25rpx;
}

.route-card {
  padding: 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 14rpx 32rpx rgba(18, 74, 64, 0.08);
}

.route-top,
.route-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.route-time,
.route-bottom {
  color: #007968;
  font-size: 22rpx;
  font-weight: 900;
}

.route-stops {
  margin-top: 14rpx;
}

.route-bottom {
  margin-top: 16rpx;
  color: #607872;
}
