<view class="page">
  <view class="group-hero">
    <view class="eyebrow">即刻凑局</view>
    <view class="group-title">不用写文案，选一下就能出门</view>
    <view class="group-desc">最多 3 人，默认 1 小时。沉默也能同路，不想走了就散。</view>
  </view>

  <view class="section">
    <view class="section-title">
      <text>今天是什么状态</text>
    </view>
    <view class="state-card card card-pad {{selectedState === item.id ? 'active' : ''}}" wx:for="{{launchStates}}" wx:key="id" data-id="{{item.id}}" bindtap="selectState">
      <view class="state-icon">{{item.icon}}</view>
      <view>
        <view class="item-title">{{item.title}}</view>
        <view class="item-desc">{{item.subtitle}}</view>
      </view>
    </view>
  </view>

  <view class="section card card-pad">
    <view class="switch-row">
      <view>
        <view class="item-title">静音同行</view>
        <view class="item-desc">不聊天，只陪着走一段。</view>
      </view>
      <switch checked="{{quiet}}" color="#f6a400" bindchange="toggleQuiet" />
    </view>
    <view class="duration-row">
      <view class="duration-chip {{duration === '1 小时' ? 'active' : ''}}" data-value="1 小时" bindtap="selectDuration">1 小时</view>
      <view class="duration-chip {{duration === '半天内' ? 'active' : ''}}" data-value="半天内" bindtap="selectDuration">半天内</view>
    </view>
  </view>

  <view class="primary-btn publish-btn" bindtap="publishGroup">发布：{{selectedTitle}}</view>

  <view class="matched-card card card-pad" wx:if="{{matched}}">
    <view class="item-title">凑上了，轻松点</view>
    <view class="item-desc">{{duration}} · {{quiet ? '静音同行' : '能聊就聊'}} · 结束自动散局</view>
    <view class="member-row">
      <view class="member" wx:for="{{matchMembers}}" wx:key="*this">{{item}}</view>
    </view>
    <view class="danger-btn" bindtap="dissolveGroup">一键散局</view>
  </view>

  <view class="matched-card card card-pad" wx:if="{{dissolved}}">
    <view class="item-title">已散局</view>
    <view class="item-desc">系统已代你通知对方，不用解释。想再出门时重新凑就行。</view>
  </view>

  <view class="section">
    <view class="section-title">
      <text>现成可以加入</text>
    </view>
    <view class="card card-pad group-item" wx:for="{{groups}}" wx:key="id" data-id="{{item.id}}" bindtap="openDetail">
      <view>
        <view class="item-title">{{item.title}}</view>
        <view class="item-desc">{{item.place}} · {{item.duration}} · {{item.status}}</view>
        <view class="tag-row">
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
        </view>
      </view>
      <view class="capacity">{{item.members}}/{{item.capacity}}</view>
    </view>
  </view>
</view>
