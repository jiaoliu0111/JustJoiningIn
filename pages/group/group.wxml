<view class="page">
  <view class="group-hero">
    <view class="eyebrow">出门理由</view>
    <view class="group-title">给你一个现在出门的小理由</view>
    <view class="group-desc">不约人，不报名，不需要准备。挑一个近的，路过看看就行。</view>
  </view>

  <view class="section card card-pad reason-main" wx:if="{{selectedMoment}}">
    <view class="tiny">推荐给你</view>
    <view class="reason-bubble">{{selectedMoment.bubble}}</view>
    <view class="item-title">{{selectedReason.title}}</view>
    <view class="item-desc">{{selectedReason.subtitle}}</view>
    <view class="reason-meta">
      <text>步行 {{selectedMoment.walkMinutes}} 分钟</text>
      <text>{{selectedMoment.timeLabel}}</text>
      <text>不用报名</text>
    </view>
    <view class="tag-row">
      <text class="tag" wx:for="{{selectedMoment.tags}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="primary-btn reason-action" bindtap="openSelected">现在去看看</view>
    <view class="secondary-btn reason-secondary" bindtap="shuffleReason">换一个近点的</view>
  </view>

  <view class="section">
    <view class="section-title">
      <text>其他轻松理由</text>
    </view>
    <view
      class="card card-pad reason-item {{selectedIndex === index ? 'active' : ''}}"
      wx:for="{{reasons}}"
      wx:key="id"
      data-index="{{index}}"
      bindtap="pickReason"
    >
      <view>
        <view class="item-title">{{item.title}}</view>
        <view class="item-desc">{{item.subtitle}}</view>
      </view>
      <view class="reason-arrow">看</view>
    </view>
  </view>
</view>
