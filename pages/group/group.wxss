.group-hero {
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #fff3d8 0%, #fffdf7 58%, #e6f1df 100%);
  box-shadow: 0 14rpx 34rpx rgba(46, 37, 31, 0.08);
}

.eyebrow {
  color: #b95d20;
  font-size: 24rpx;
  font-weight: 700;
}

.group-title {
  margin-top: 18rpx;
  color: #2e251f;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.2;
}

.group-desc {
  margin-top: 14rpx;
  color: #766c5b;
  font-size: 27rpx;
  line-height: 1.55;
}

.reason-bubble {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin: 16rpx 0 24rpx;
  min-height: 58rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #ff8a3d;
  color: #fffdf7;
  font-size: 28rpx;
  font-weight: 900;
}

.reason-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
  color: #7b6b5d;
  font-size: 24rpx;
}

.reason-action {
  margin-top: 24rpx;
}

.reason-secondary {
  margin-top: 14rpx;
}

.reason-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border: 3rpx solid transparent;
}

.reason-item.active {
  border-color: #ff8a3d;
}

.reason-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #e8f4df;
  color: #4f8548;
  font-size: 24rpx;
  font-weight: 900;
  flex: 0 0 auto;
}
