<view class="page bustle-page">
  <view class="brand-bar">
    <view class="brand-mark">⌘</view>
    <text>Join the Fun</text>
    <text class="brand-bell">⌂</text>
  </view>

  <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="filter-row">
      <view
        wx:for="{{filters}}"
        wx:key="id"
        class="filter-chip {{activeFilter === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectFilter"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <view class="loading-card card" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <view class="loading-copy">
      <view class="item-title">正在加载{{activeFilterLabel}}</view>
      <view class="item-desc">正在整理附近值得看的活动，马上就好。</view>
    </view>
  </view>

  <view class="event-list" wx:else>
    <block wx:for="{{visibleCards}}" wx:key="id">
      <view class="event-card card" data-type="{{item.cardType}}" data-id="{{item.id}}" bindtap="openDetail">
        <view class="cover-wrap">
          <image class="event-cover" src="{{item.image}}" mode="aspectFill" />
          <view class="cover-badge">{{item.category || item.badge}}</view>
          <view class="heart-btn">♡</view>
        </view>
        <view class="event-body">
          <view class="event-head">
            <view class="item-title">{{item.title}}</view>
            <view class="price">{{item.priceLabel || '免费参加'}}</view>
          </view>
          <view class="item-desc">{{item.description}}</view>
          <view class="meta-row">
            <text>⌖ {{item.displayPlace}}</text>
            <text>▣ {{item.displayTime}}</text>
          </view>
          <view class="primary-btn event-action">开启导航</view>
        </view>
      </view>
    </block>
  </view>

  <view class="card card-pad empty-state" wx:if="{{errorText}}">
    <view class="item-title">热闹暂时没加载出来</view>
    <view class="item-desc">{{errorText}}</view>
  </view>
</view>
