.bustle-page {
  padding-top: 248rpx;
  padding-bottom: 140rpx;
}

.bustle-fixed-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 30;
  padding: 58rpx 38rpx 22rpx;
  background: #f3faf8;
  box-sizing: border-box;
}

.filter-scroll {
  margin: 28rpx -38rpx 0;
  padding: 0 38rpx 14rpx;
  background: #f3faf8;
  white-space: nowrap;
  box-sizing: border-box;
}

.filter-row {
  display: inline-flex;
  gap: 14rpx;
  padding: 0 2rpx 8rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #334c47;
  font-size: 22rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 22rpx rgba(11, 78, 67, 0.06);
}

.filter-chip.active {
  background: #8fe5d0;
  color: #007968;
}

.event-list {
  margin-top: 12rpx;
}

.loading-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-height: 150rpx;
  margin-top: 12rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(0, 121, 104, 0.08);
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(11, 78, 67, 0.07);
}

.loading-spinner {
  width: 52rpx;
  height: 52rpx;
  border: 6rpx solid #dff7f1;
  border-top-color: #007968;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
  flex: 0 0 52rpx;
}

.loading-copy {
  flex: 1;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.event-card {
  overflow: hidden;
}

.cover-wrap {
  position: relative;
  height: 320rpx;
  background: #d9f4ed;
}

.event-cover {
  display: block;
  width: 100%;
  height: 100%;
}

.cover-badge {
  position: absolute;
  left: 16rpx;
  bottom: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #173d36;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 900;
}

.heart-btn {
  position: absolute;
  right: 18rpx;
  top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #007968;
  font-size: 34rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 18rpx rgba(11, 78, 67, 0.12);
}

.event-body {
  padding: 24rpx 24rpx 26rpx;
}

.event-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.title-link {
  flex: 1;
  min-width: 0;
  color: #173d36;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.35;
}

.title-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 30rpx;
  margin-left: 10rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #d9f7ef;
  color: #007968;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 30rpx;
  vertical-align: middle;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.source-tag {
  max-width: 220rpx;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: #d9f7ef;
  color: #007968;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 58rpx;
  margin-top: 12rpx;
}

.place-meta {
  display: flex;
  align-items: center;
  min-width: 0;
  min-height: 34rpx;
  color: #6a7e79;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.place-pin-icon {
  flex: 0 0 auto;
  display: block;
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
  transform: translateY(1rpx);
}

.place-name {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.map-icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 52rpx;
  height: 52rpx;
  margin-left: auto;
  border-radius: 50%;
  background: #e7faf5;
  color: #007968;
  box-shadow: 0 6rpx 16rpx rgba(0, 121, 104, 0.1);
}

.map-pin {
  position: relative;
  width: 22rpx;
  height: 22rpx;
  border-radius: 50% 50% 50% 0;
  background: #007968;
  transform: rotate(-45deg);
}

.map-pin-dot {
  position: absolute;
  left: 6rpx;
  top: 6rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #ffffff;
}
