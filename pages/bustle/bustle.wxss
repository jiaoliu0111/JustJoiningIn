.bustle-head {
  padding: 32rpx 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #fff3d8 0%, #fffdf7 54%, #e6f1df 100%);
  box-shadow: 0 14rpx 34rpx rgba(46, 37, 31, 0.08);
}

.eyebrow {
  color: #b95d20;
  font-size: 24rpx;
  font-weight: 700;
}

.head-title {
  margin-top: 18rpx;
  color: #2e251f;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.2;
}

.head-desc {
  margin-top: 14rpx;
  color: #766c5b;
  font-size: 27rpx;
  line-height: 1.55;
}

.filter-scroll {
  margin-top: 24rpx;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 12rpx;
  padding-bottom: 4rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #fffdf7;
  color: #7b6b5d;
  font-size: 25rpx;
  box-shadow: 0 8rpx 18rpx rgba(76, 52, 20, 0.06);
}

.filter-chip.active {
  background: #ff8a3d;
  color: #fffdf7;
  font-weight: 800;
}

.bustle-card {
  position: relative;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.badge {
  display: inline-flex;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f4df;
  color: #4f8548;
  font-size: 22rpx;
  font-weight: 700;
}
