.bustle-page {
  padding-bottom: 140rpx;
}

.filter-scroll {
  margin-top: 34rpx;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 14rpx;
  padding: 0 2rpx 8rpx;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #334c47;
  font-size: 22rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 22rpx rgba(11, 78, 67, 0.06);
}

.filter-chip.active {
  background: #8fe5d0;
  color: #007968;
}

.event-list {
  margin-top: 32rpx;
}

.loading-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-height: 150rpx;
  margin-top: 32rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(0, 121, 104, 0.08);
  background: #ffffff;
  box-shadow: 0 14rpx 34rpx rgba(11, 78, 67, 0.07);
}

.loading-spinner {
  width: 52rpx;
  height: 52rpx;
  border: 6rpx solid #dff7f1;
  border-top-color: #007968;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
  flex: 0 0 52rpx;
}

.loading-copy {
  flex: 1;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.event-card {
  overflow: hidden;
}

.cover-wrap {
  position: relative;
  height: 320rpx;
  background: #d9f4ed;
}

.event-cover {
  display: block;
  width: 100%;
  height: 100%;
}

.cover-badge {
  position: absolute;
  left: 16rpx;
  bottom: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #173d36;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 900;
}

.heart-btn {
  position: absolute;
  right: 18rpx;
  top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #ffffff;
  color: #007968;
  font-size: 34rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 18rpx rgba(11, 78, 67, 0.12);
}

.event-body {
  padding: 24rpx 24rpx 26rpx;
}

.event-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.price {
  color: #173d36;
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
}

.event-action {
  min-height: 62rpx;
  margin-top: 20rpx;
  font-size: 23rpx;
}
