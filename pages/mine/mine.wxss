.mine-head {
  display: flex;
  align-items: center;
  gap: 22rpx;
  background: linear-gradient(135deg, #fff3d8 0%, #fffdf7 58%, #e6f1df 100%);
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: #ff8a3d;
  color: #fffdf7;
  font-size: 42rpx;
  font-weight: 900;
  flex: 0 0 auto;
}

.distance-row {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}

.distance-chip {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 74rpx;
  border-radius: 999rpx;
  background: #fff3d8;
  color: #766c5b;
  font-size: 27rpx;
  font-weight: 700;
}

.distance-chip.active {
  background: #ff8a3d;
  color: #fffdf7;
}

.pref-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(120, 99, 56, 0.1);
}

.pref-row:first-of-type {
  border-top: 0;
}

.check-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding-top: 18rpx;
  color: #5e5548;
  font-size: 28rpx;
}

.check-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ff8a3d;
}
