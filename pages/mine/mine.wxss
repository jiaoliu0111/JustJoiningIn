.mine-page {
  padding-bottom: 150rpx;
}

.mine-hero {
  margin-top: 34rpx;
  padding: 34rpx 30rpx;
  border-radius: 32rpx;
  background: #fff8ec;
  border: 2rpx solid rgba(255, 138, 61, 0.18);
  box-shadow: 0 18rpx 44rpx rgba(90, 67, 46, 0.08);
}

.eyebrow {
  color: #ff8a3d;
  font-size: 24rpx;
  font-weight: 900;
}

.mine-title {
  margin-top: 12rpx;
  color: #173d36;
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 900;
}

.mine-desc {
  margin-top: 12rpx;
  color: #5f746f;
  font-size: 25rpx;
  line-height: 1.58;
}

.preference-card {
  margin-top: 24rpx;
}

.walk-options {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.walk-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 66rpx;
  border-radius: 999rpx;
  background: #e7faf5;
  color: #007968;
  font-size: 24rpx;
  font-weight: 900;
}

.walk-chip.active {
  background: #007968;
  color: #ffffff;
}

.pref-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
  padding: 22rpx 0;
  border-bottom: 2rpx solid #eef6f3;
}

.pref-row:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.menu-copy {
  flex: 1;
  min-width: 0;
}

.checklist {
  display: grid;
  gap: 14rpx;
}

.check-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 64rpx;
  color: #38554f;
  font-size: 25rpx;
  font-weight: 800;
}

.check-dot {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #ffd2ad;
  color: #b86532;
  font-size: 22rpx;
  font-weight: 900;
}
