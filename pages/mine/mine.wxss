.mine-page {
  padding-bottom: 150rpx;
}

.profile-hero {
  margin-top: 72rpx;
  text-align: center;
}

.profile-illustration {
  display: block;
  width: 220rpx;
  height: 180rpx;
  margin: 0 auto;
  border-radius: 8rpx;
  background: #f7eee4;
}

.profile-title {
  margin-top: 30rpx;
  color: #173d36;
  font-size: 25rpx;
  font-weight: 800;
}

.profile-desc {
  margin-top: 12rpx;
  color: #6c817c;
  font-size: 22rpx;
}

.login-btn {
  width: 420rpx;
  min-height: 72rpx;
  margin: 34rpx auto 0;
  font-size: 24rpx;
}

.mine-menu {
  margin-top: 58rpx;
}

.menu-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  min-height: 104rpx;
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.78);
  box-sizing: border-box;
}

.menu-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 900;
  flex: 0 0 auto;
}

.menu-icon.heart {
  background: #fff0e6;
  color: #d28a55;
}

.menu-icon.note {
  background: #dff8f1;
  color: #007968;
}

.menu-copy {
  flex: 1;
  min-width: 0;
}

.menu-arrow {
  color: #91a39f;
  font-size: 42rpx;
}

.mine-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 70rpx;
  margin-top: 74rpx;
  color: #31524b;
  font-size: 23rpx;
}
