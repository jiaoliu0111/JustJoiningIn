<view class="page">
  <view class="mine-head card card-pad">
    <view class="avatar">凑</view>
    <view>
      <view class="item-title">周末轻装用户</view>
      <view class="item-desc">不经营人设，不攒积分，只记录自己出过门。</view>
    </view>
  </view>

  <view class="section card card-pad">
    <view class="section-title">
      <text>安全距离</text>
    </view>
    <view class="item-desc">默认只看附近热闹，远的就先算了。</view>
    <view class="distance-row">
      <view
        wx:for="{{distances}}"
        wx:key="*this"
        class="distance-chip {{preferences.maxDistance === item ? 'active' : ''}}"
        data-value="{{item}}"
        bindtap="selectDistance"
      >
        {{item}}km
      </view>
    </view>
  </view>

  <view class="section card card-pad">
    <view class="section-title">
      <text>减负偏好</text>
    </view>
    <view class="pref-row">
      <view>
        <view class="item-title">默认匿名</view>
        <view class="item-desc">短时结伴，不留下社交痕迹。</view>
      </view>
      <switch checked="{{preferences.anonymous}}" color="#f6a400" data-key="anonymous" bindchange="togglePreference" />
    </view>
    <view class="pref-row">
      <view>
        <view class="item-title">接受静音同行</view>
        <view class="item-desc">不聊天，只陪伴。</view>
      </view>
      <switch checked="{{preferences.quietFriendly}}" color="#f6a400" data-key="quietFriendly" bindchange="togglePreference" />
    </view>
    <view class="pref-row">
      <view>
        <view class="item-title">周末轻提醒</view>
        <view class="item-desc">只在周末顺手提醒，不催。</view>
      </view>
      <switch checked="{{preferences.weekendReminder}}" color="#f6a400" data-key="weekendReminder" bindchange="togglePreference" />
    </view>
  </view>

  <view class="section card card-pad">
    <view class="section-title">
      <text>极简出门清单</text>
    </view>
    <view class="check-item" wx:for="{{checklist}}" wx:key="*this">
      <text class="check-dot"></text>
      <text>{{item}}</text>
    </view>
  </view>
</view>
