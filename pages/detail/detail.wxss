.detail-hero {
  padding-top: 34rpx;
  background: #ffffff;
}

.detail-title {
  margin-top: 18rpx;
  color: #173d36;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.28;
}

.article-card {
  margin-top: 24rpx;
  padding: 0 0 36rpx;
}

.detail-loading-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  min-height: 142rpx;
  border: 1rpx solid rgba(0, 121, 104, 0.08);
  background: #ffffff;
}

.loading-spinner {
  width: 52rpx;
  height: 52rpx;
  border: 6rpx solid #dff7f1;
  border-top-color: #007968;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
  flex: 0 0 52rpx;
}

.loading-copy {
  flex: 1;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.detail-image {
  display: block;
  width: 100%;
  height: 360rpx;
  margin-bottom: 28rpx;
  border-radius: 22rpx;
}

.article-card .detail-content-image {
  display: block;
  width: 100%;
  max-width: 100%;
  margin: 18rpx 0;
  border-radius: 18rpx;
}

.article-card .detail-content-paragraph,
.article-fallback {
  color: #304a43;
  font-size: 29rpx;
  line-height: 1.75;
  margin: 18rpx 0;
}
