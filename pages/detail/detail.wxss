.detail-hero {
  padding-top: 34rpx;
  background: linear-gradient(145deg, #fff1bf 0%, #fffdf6 58%, #e5f1cb 100%);
}

.detail-title {
  margin-top: 18rpx;
  color: #2f2a20;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.22;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.info-item {
  display: flex;
  align-items: center;
  min-height: 74rpx;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: #fff8ea;
  color: #6c614f;
  font-size: 25rpx;
  line-height: 1.35;
}

.stop,
.rule {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 12rpx 0;
  color: #5e5548;
  font-size: 27rpx;
  line-height: 1.45;
}

.stop-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #f6a400;
}

.detail-action {
  margin-top: 28rpx;
}
