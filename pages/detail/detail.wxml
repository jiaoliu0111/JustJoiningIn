<view class="page detail-page" wx:if="{{detail}}">
  <view class="detail-hero card card-pad">
    <view class="tiny">{{title}}</view>
    <view class="detail-title">{{detail.title}}</view>
    <view class="item-desc">{{detail.description}}</view>
    <view class="tag-row">
      <text class="tag" wx:for="{{detail.tags}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <view class="section card card-pad">
    <view class="section-title">
      <text>轻松信息</text>
    </view>
    <view class="info-grid">
      <view class="info-item" wx:for="{{meta}}" wx:key="*this">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <view class="section card card-pad" wx:if="{{type === 'route'}}">
    <view class="section-title">
      <text>顺路经过</text>
    </view>
    <view class="stop" wx:for="{{detail.stops}}" wx:key="*this">
      <text class="stop-dot"></text>
      <text>{{item}}</text>
    </view>
  </view>

  <view class="section card card-pad" wx:if="{{type === 'group'}}">
    <view class="section-title">
      <text>减负规则</text>
    </view>
    <view class="rule">最多 {{detail.capacity}} 人，不变成团建。</view>
    <view class="rule">{{detail.duration}} 后自动散局，不用维持关系。</view>
    <view class="rule" wx:if="{{detail.quiet}}">静音同行，不聊天也没关系。</view>
    <view class="rule" wx:if="{{detail.anonymous}}">短时匿名，结束后不留社交痕迹。</view>
  </view>

  <view class="primary-btn detail-action" bindtap="takeAction">{{primaryText}}</view>
</view>

<view class="page empty-page" wx:else>
  <view class="card card-pad">
    <view class="item-title">没找到这个热闹</view>
    <view class="item-desc">可能已经散局了，回首页看看附近还有什么。</view>
  </view>
</view>
