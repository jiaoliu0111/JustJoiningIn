<view class="page detail-page" wx:if="{{detail}}">
  <view class="detail-hero card card-pad">
    <view class="detail-title">{{detail.title}}</view>
    <view class="item-desc">{{detail.sourceName}}</view>
  </view>

  <view class="article-card">
    <image wx:if="{{detail.image}}" class="detail-image" src="{{detail.image}}" mode="aspectFill" />
    <view wx:if="{{loading && (!detail.contentNodes || !detail.contentNodes.length)}}" class="detail-loading-card card card-pad">
      <view class="loading-spinner"></view>
      <view class="loading-copy">
        <view class="item-title">正在加载详情</view>
      </view>
    </view>
    <rich-text wx:elif="{{detail.contentNodes && detail.contentNodes.length}}" nodes="{{detail.contentNodes}}"></rich-text>
    <view wx:else class="article-fallback">{{detail.description}}</view>
  </view>
</view>

<view class="page detail-page" wx:elif="{{loading}}">
  <view class="detail-loading-card card card-pad">
    <view class="loading-spinner"></view>
    <view class="loading-copy">
      <view class="item-title">正在加载详情</view>
    </view>
  </view>
</view>

<view class="page empty-page" wx:else>
  <view class="card card-pad">
    <view class="item-title">没找到这个热闹</view>
    <view class="item-desc">可能已经结束了，回首页看看附近还有什么。</view>
  </view>
</view>
