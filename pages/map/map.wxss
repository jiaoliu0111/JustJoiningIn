.map-page {
  padding-bottom: 150rpx;
}

.map-stage {
  position: relative;
  height: 860rpx;
  margin-top: 34rpx;
  overflow: hidden;
  border-radius: 34rpx;
  background:
    linear-gradient(90deg, rgba(210, 226, 220, 0.42) 2rpx, transparent 2rpx) 0 0 / 72rpx 72rpx,
    linear-gradient(0deg, rgba(210, 226, 220, 0.42) 2rpx, transparent 2rpx) 0 0 / 72rpx 72rpx,
    #f8fcfa;
  border: 2rpx solid #e4efeb;
}

.map-water {
  position: absolute;
  left: -80rpx;
  right: -80rpx;
  bottom: 145rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #c7ece6;
  transform: rotate(-10deg);
}

.map-road {
  position: absolute;
  height: 34rpx;
  border-radius: 999rpx;
  background: #dfe8e4;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.8);
}

.road-one {
  left: -90rpx;
  top: 230rpx;
  width: 860rpx;
  transform: rotate(21deg);
}

.road-two {
  left: 120rpx;
  top: 150rpx;
  width: 560rpx;
  transform: rotate(-46deg);
}

.road-three {
  left: -70rpx;
  top: 560rpx;
  width: 820rpx;
  transform: rotate(-8deg);
}

.map-center {
  position: absolute;
  left: 48%;
  top: 44%;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #007968;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  box-shadow: 0 0 0 14rpx rgba(0, 121, 104, 0.14);
}

.map-marker {
  position: absolute;
  display: flex;
  align-items: center;
  gap: 8rpx;
  max-width: 230rpx;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #203a35;
  font-size: 22rpx;
  font-weight: 800;
  box-shadow: 0 12rpx 30rpx rgba(15, 68, 58, 0.12);
  transform: translate(-50%, -50%);
}

.marker-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #007968;
  flex: 0 0 auto;
}

.marker-mint .marker-dot {
  background: #69d6bd;
}

.marker-green .marker-dot {
  background: #007968;
}

.marker-peach .marker-dot {
  background: #ffb98f;
}

.map-card {
  margin-top: 26rpx;
}

.map-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.price-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #e7faf5;
  color: #007968;
  font-size: 22rpx;
  font-weight: 800;
  flex: 0 0 auto;
}

.map-action {
  margin-top: 22rpx;
}
